# AI Daily Briefing - 环境变量配置
# 复制此文件为 .env 并填入你的配置

# ── 必须 ──────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
# 可选: gpt-4o（质量更高但贵约10倍）

# ── Slack 推送（推荐） ────────────────────────────
# 中文版 Block Kit
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# 日本語版（別チャンネル）
SLACK_WEBHOOK_URL_JA=https://hooks.slack.com/services/xxx/yyy/zzz

# ── Telegram 推送（可选） ─────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNO
TELEGRAM_CHAT_ID=你的ChatID

# ── Google Sheets 归档（可选） ────────────────────
GOOGLE_SHEET_ID=你的SpreadsheetID
GOOGLE_CREDENTIALS_FILE=credentials.json
